# 强制 LF 行尾规范化(治 enhanced-boundaries #3 CRLF)
* text=auto eol=lf

*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.md text eol=lf
*.json text eol=lf
*.ps1 text eol=lf

# 二进制资源
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.svg text eol=lf
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary
*.glb binary
*.gltf binary
