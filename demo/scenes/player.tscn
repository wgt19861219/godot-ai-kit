[gd_scene load_steps=4 format=3]

; player.tscn — 3D 收集物平台游戏玩家骨架
; 手写骨架(非 enhanced 生成)。生产阶段可用 enhanced add_node + save_scene 重建。
; spec §6.3 架构阶段 | plan2 Task 6 Step 3
; 节点树设计见 demo/docs/02-architecture-adr.md

[ext_resource type="Script" path="res://scenes/player.gd" id="1_player"]
; 注:player.gd 由 ③ production 阶段创建(MVP 不存在,load 时需注释本行或创建空脚本)

[sub_resource type="CapsuleMesh" id="CapsuleMesh_player"]
radius = 0.4
height = 1.6

[sub_resource type="CapsuleShape3D" id="CapsuleShape3D_player"]
radius = 0.4
height = 1.6

[node name="Player" type="CharacterBody3D"]
script = ExtResource("1_player")

[node name="MeshInstance3D" type="MeshInstance3D" parent="."]
mesh = SubResource("CapsuleMesh_player")
; 蓝色材质(MVP 用原色,v1 接低多边形资产)

[node name="CollisionShape3D" type="CollisionShape3D" parent="."]
shape = SubResource("CapsuleShape3D_player")

[node name="SpringArm3D" type="SpringArm3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.0, 0)
spring_length = 4.0
; 第三人称相机臂:v1 加旋转逻辑(鼠标 X/Y)

[node name="Camera3D" type="Camera3D" parent="SpringArm3D"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 0)
fov = 70.0
